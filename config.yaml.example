# Minimal bootstrap config. All other settings (LDAP, DNS, security,
# session TTLs, proxy host/port, relay options) are managed through
# the admin panel → Settings page and stored in the database.

instance:
  id: "node-1"
  lan_ip: "10.120.0.13"

database:
  url: "postgresql+asyncpg://rdpproxy:CHANGE_ME@postgres:5432/rdpproxy"
  pool_size: 20
  max_overflow: 10

redis:
  host: "redis"
  port: 6379
  password: "CHANGE_ME"
  db: 0

security:
  encryption_key: "GENERATE_WITH_openssl_rand_hex_32"

proxy:
  cert_path: "/etc/letsencrypt/live/rdp.example.com/fullchain.pem"
  key_path: "/etc/letsencrypt/live/rdp.example.com/privkey.pem"

# Bind addresses — change only for non-standard setups
portal:
  host: "0.0.0.0"
  port: 8001

admin:
  host: "0.0.0.0"
  port: 9090

rdp_relay:
  host: "0.0.0.0"
  port: 8002

# ── Optional: LDAP / DNS / etc. can still be set here for initial seed ──
# If present, values are migrated to the database on first startup and
# then managed exclusively through the admin panel.
#
# ldap:
#   server: "dc01.example.com"
#   mode: "plain"
#   port: 389
#   tls_verify: false
#   bind_dn: "CN=serviceuser,OU=...,DC=example,DC=com"
#   bind_password: "YOUR_BIND_PASSWORD"
#   users_dn: "OU=Users,DC=example,DC=com"
#   domain: "example.com"
#
# dns:
#   servers:
#     - "10.100.0.2"
#   timeout: 3
#   cache_ttl: 300
